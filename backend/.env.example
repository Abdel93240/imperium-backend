APP_NAME=Personal AI OS API
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_ai_os
DATABASE_CONNECT_TIMEOUT_SECONDS=2

JWT_SECRET_KEY=change-me-before-use
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

INTERNAL_WEBHOOK_SECRET=change-me-before-use
WEBHOOK_SIGNATURE_ALGORITHM=HMAC-SHA256
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=60
